# GLOT-Link 웹 결제 (Vercel 환경변수에 설정 — 커밋 금지)
# 로컬: .env.local 파일에 동일 키 입력

# Supabase (GLOT-Link 앱과 동일 프로젝트)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# PortOne V2 — https://admin.portone.io
VITE_PORTONE_STORE_ID=store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_PORTONE_BILLING_CHANNEL_KEY=channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 간편결제 정기 (카카오페이 심사)
VITE_PORTONE_BILLING_METHOD=EASY_PAY
VITE_PORTONE_EASY_PAY_PROVIDER=KAKAOPAY

# 공개 기능 (결제·코드서명 준비 전까지 false 유지)
VITE_DOWNLOAD_ENABLED=false
VITE_CHECKOUT_ENABLED=false
